{
  "name": "@derneuere/visual-react",
  "version": "0.3.0",
  "description": "A React-based visual CMS framework: headless page/component tree core with an optional Mantine-based visual editor",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/derneuere/visual-react.git"
  },
  "homepage": "https://github.com/derneuere/visual-react#readme",
  "bugs": {
    "url": "https://github.com/derneuere/visual-react/issues"
  },
  "keywords": [
    "react",
    "cms",
    "visual-editor",
    "page-builder",
    "drag-and-drop",
    "mantine",
    "headless-cms"
  ],
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./editor": {
      "types": "./dist/editor.d.ts",
      "import": "./dist/editor.js"
    },
    "./editor/dnd": {
      "types": "./dist/editor-dnd.d.ts",
      "import": "./dist/editor-dnd.js"
    },
    "./canvas": {
      "types": "./dist/canvas.d.ts",
      "import": "./dist/canvas.js"
    },
    "./canvas/dnd": {
      "types": "./dist/canvas-dnd.d.ts",
      "import": "./dist/canvas-dnd.js"
    },
    "./editor.css": "./dist/editor.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build",
    "build:types": "tsc --emitDeclarationOnly",
    "prepare": "npm run build && npm run build:types",
    "lint": "eslint src --ext ts,tsx",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@dnd-kit/core": "^6.2.0",
    "@dnd-kit/sortable": "^9.0.0 || ^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mantine/core": "^8.0.0",
    "@mantine/hooks": "^8.0.0",
    "@mantine/tiptap": "^8.0.0",
    "@tabler/icons-react": "^3.17.0",
    "@tanstack/react-query": "^5.62.11",
    "@tiptap/extension-link": "^3.0.0",
    "@tiptap/pm": "^3.0.0",
    "@tiptap/react": "^3.0.0",
    "@tiptap/starter-kit": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-error-boundary": "^4.1.2"
  },
  "peerDependenciesMeta": {
    "@dnd-kit/core": {
      "optional": true
    },
    "@dnd-kit/sortable": {
      "optional": true
    },
    "@dnd-kit/utilities": {
      "optional": true
    },
    "@mantine/core": {
      "optional": true
    },
    "@mantine/hooks": {
      "optional": true
    },
    "@mantine/tiptap": {
      "optional": true
    },
    "@tabler/icons-react": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    },
    "@tiptap/extension-link": {
      "optional": true
    },
    "@tiptap/pm": {
      "optional": true
    },
    "@tiptap/react": {
      "optional": true
    },
    "@tiptap/starter-kit": {
      "optional": true
    },
    "react-error-boundary": {
      "optional": true
    }
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.2.0",
    "@dnd-kit/sortable": "^9.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mantine/core": "^8.0.0",
    "@mantine/hooks": "^8.0.0",
    "@mantine/tiptap": "^8.0.0",
    "@tabler/icons-react": "^3.17.0",
    "@tanstack/react-query": "^5.62.11",
    "@tiptap/extension-link": "^3.0.0",
    "@tiptap/pm": "^3.0.0",
    "@tiptap/react": "^3.0.0",
    "@tiptap/starter-kit": "^3.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-error-boundary": "^4.1.2",
    "typescript": "~5.6.2",
    "vite": "^7.0.0",
    "vite-plugin-externalize-deps": "^0.10.0",
    "vitest": "^4.1.0"
  }
}
