# visual-react demo - example environment variables
# Copy this file to .env and adjust for your setup.
# The demo also runs without a .env (defaults shown below).

# Public origin of this app. Used by the SSR page loader to fetch its own
# /api/pages/* routes, so it must be an absolute URL.
# Default: http://localhost:3000 (the dev server port)
VITE_URL=http://localhost:3000

# Storage backend for page content: "local" | "github" | "django"
# local  = file-based storage via this app's API routes (pages/*.json)
# github = GitHubStorageAdapter (see VITE_GITHUB_* below)
# django = the example Python backend in ../backend
VITE_STORAGE_MODE=local

# Only for VITE_STORAGE_MODE=django:
#VITE_DJANGO_URL=http://localhost:8000

# Only for VITE_STORAGE_MODE=github:
#VITE_GITHUB_OWNER=
#VITE_GITHUB_REPO=
#VITE_GITHUB_TOKEN=
